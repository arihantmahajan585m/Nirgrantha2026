# OpenAI API (same stack as ChatGPT). Get a key: https://platform.openai.com/api-keys
# Do NOT use the VITE_ prefix — this file is read only by the Vite dev/preview server
# so the key is not bundled into the browser.
OPENAI_API_KEY=

# Optional — default is gpt-4o-mini (fast and low cost)
# OPENAI_MODEL=gpt-4o-mini

# Optional — if you deploy a backend that proxies to OpenAI, set in .env.production:
# VITE_OPENAI_PROXY_URL=https://your-api.example.com/chat

# Insecure fallback (key visible in client JS) — only for static demos:
# VITE_OPENAI_API_KEY=
# VITE_OPENAI_MODEL=gpt-4o-mini

# Pollinations (free, no key) — Faculty hub "Free AI" mode. Default model is "openai".
# VITE_POLLINATIONS_MODEL=openai
